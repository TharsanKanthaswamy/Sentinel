      <bpmn:sequenceFlow id="edge_eventSubprocessSLAParallelGateway-eventSubprocessExclusiveGateway" sourceRef="eventSubprocessSLAParallelGateway" targetRef="eventSubprocessExclusiveGateway" />
      <bpmn:sequenceFlow id="edge_eventSubprocessSLAInclusiveGateway-eventSubprocessStagesExitedInclusiveGateway" sourceRef="eventSubprocessSLAInclusiveGateway" targetRef="eventSubprocessStagesExitedInclusiveGateway">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions != null &amp;&amp; ((vars.caseManagerDecisions.stagesExited != null &amp;&amp; vars.caseManagerDecisions.stagesExited.length &gt; 0) || (vars.caseManagerDecisions.stagesCompleted != null &amp;&amp; vars.caseManagerDecisions.stagesCompleted.length &gt; 0)))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_eventSubprocessSLAInclusiveGateway-eventSubprocessStagesEnteredInclusiveGateway" sourceRef="eventSubprocessSLAInclusiveGateway" targetRef="eventSubprocessStagesEnteredInclusiveGateway">
