      <bpmn:sequenceFlow id="edge_EventSubProcessRetrieveCaseStateNodePostCaseManager-eventSubprocessSLAParallelGateway" sourceRef="EventSubProcessRetrieveCaseStateNodePostCaseManager" targetRef="eventSubprocessSLAParallelGateway" />
      <bpmn:sequenceFlow id="edge_eventSubprocessSLAParallelGateway-eventSubprocessSLAInclusiveGateway" sourceRef="eventSubprocessSLAParallelGateway" targetRef="eventSubprocessSLAInclusiveGateway" />
