            </uipath:context>
            <uipath:input name="caseManagerInput" type="json" target="body"><![CDATA[{"caseDeterministicRules":{"case":{"completionConditions":[{"completionConditionType":"StagesCompleted","parameters":{"stageNames":["1 – Initial AI Screening","2 – Human Investigation Review","3 – AI Network Investigation","4 – Final Report & Closure"]},"ruleName":"Case complete rule"}]},"stages":[{"name":"1 – Initial AI Screening","entryConditions":[{"entryConditionType":"CaseEntered","parameters":{},"ruleName":"Stage entry"}],"exitConditions":[],"completionConditions":[{"completionConditionType":"TasksCompleted","parameters":{"taskNames":["RPA Workflow"]},"ruleName":"Tasks completed rule"}],"tasks":[{"name":"RPA Workflow","runOnlyOnce":false,"entryConditions":[{"entryConditionType":"StageEntered","parameters":{"stageNames":["1 – Initial AI Screening"]},"ruleName":"Entry rule 1"}]}]},{"name":"2 – Human Investigation Review","entryConditions":[{"entryConditionType":"StagesCompleted","parameters":{"stageNames":["1 – Initial AI Screening"]},"ruleName":"Entry from Stage 1"}],"exitConditions":[],"completionConditions":[{"completionConditionType":"TasksCompleted","parameters":{"taskNames":["SimpleApprovalApp"]},"ruleName":"Completion rule 1"}],"tasks":[{"name":"SimpleApprovalApp","runOnlyOnce":false,"entryConditions":[{"entryConditionType":"StageEntered","parameters":{"stageNames":["2 – Human Investigation Review"]},"ruleName":"Entry rule 1"}]}]},{"name":"3 – AI Network Investigation","entryConditions":[{"entryConditionType":"StagesCompleted","parameters":{"stageNames":["2 – Human Investigation Review"]},"ruleName":"Entry from Stage 2"}],"exitConditions":[],"completionConditions":[],"tasks":[]},{"name":"4 – Final Report & Closure","entryConditions":[{"entryConditionType":"StagesCompleted","parameters":{"stageNames":["3 – AI Network Investigation"]},"ruleName":"Entry from Stage 3"}],"exitConditions":[],"completionConditions":[],"tasks":[]}],"version":1},"caseCurrentExecutionState":"=js:({ \"version\": 1, \"eventIdentifier\": vars.EventSubProcessEventIdentifier, \"event\": { \"type\": vars.EventSubProcessLatestEventType, \"parameters\": vars.EventSubProcessLatestEventParams, \"isExternal\": (vars.EventSubProcessLatestEventType == \"CaseEntered\" || vars.EventSubProcessLatestEventType == \"TaskCompleted\") ? false : true }, \"state\": { ...vars.caseState, \"vars\": { \"RPA Workflow\": { \"Error\": (vars.error), \"riskScore\": (vars.riskScore2), \"accountId\": (vars.accountId2), \"riskLevel\": (vars.riskLevel2), \"flags\": (vars.flags2), \"isSuspicious\": (vars.isSuspicious2) }, \"SimpleApprovalApp\": { \"Error\": (vars.error2), \"Comment\": (vars.comment), \"Action\": (vars.action), \"hitlTask\": (vars.hitlTask) }, \"Received event params\": { \"response\": (vars.mainEventSubprocessResponse.connectorResponse) }, \"APIEvent\": (vars.mainEventSubprocessResponse.apiEvent) } } })"}]]></uipath:input>
            <uipath:output name="caseRulesDecisions" type="json" source="=result" var="caseRulesDecisions" custom="true" />
