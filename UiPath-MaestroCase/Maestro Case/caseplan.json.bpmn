      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_eventSubprocessSLAInclusiveGateway-eventSubprocessNoStagesToEnterExitEndEvent" sourceRef="eventSubprocessSLAInclusiveGateway" targetRef="eventSubprocessNoStagesToEnterExitEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions == null || ((vars.caseManagerDecisions.stagesEntered == null || vars.caseManagerDecisions.stagesEntered.length == 0) &amp;&amp; (vars.caseManagerDecisions.stagesExited == null || vars.caseManagerDecisions.stagesExited.length == 0) &amp;&amp; (vars.caseManagerDecisions.stagesCompleted == null || vars.caseManagerDecisions.stagesCompleted.length == 0)))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_eventSubprocessStagesExitedInclusiveGateway-stopStageSlaMessageEvent_stage_1" sourceRef="eventSubprocessStagesExitedInclusiveGateway" targetRef="stopStageSlaMessageEvent_stage_1">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:((vars.caseManagerDecisions.stagesExited != null &amp;&amp; vars.caseManagerDecisions.stagesExited.length &gt; 0 &amp;&amp; vars.caseManagerDecisions.stagesExited.some((stage) =&gt; stage.stageName == '1 – Initial AI Screening')) || (vars.caseManagerDecisions.stagesCompleted != null &amp;&amp; vars.caseManagerDecisions.stagesCompleted.length &gt; 0 &amp;&amp; vars.caseManagerDecisions.stagesCompleted.some((stage) =&gt; stage.stageName == '1 – Initial AI Screening')))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_eventSubprocessStagesExitedInclusiveGateway-stopStageSlaMessageEvent_Stage_RBNERo" sourceRef="eventSubprocessStagesExitedInclusiveGateway" targetRef="stopStageSlaMessageEvent_Stage_RBNERo">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:((vars.caseManagerDecisions.stagesExited != null &amp;&amp; vars.caseManagerDecisions.stagesExited.length &gt; 0 &amp;&amp; vars.caseManagerDecisions.stagesExited.some((stage) =&gt; stage.stageName == '2 – Human Investigation Review')) || (vars.caseManagerDecisions.stagesCompleted != null &amp;&amp; vars.caseManagerDecisions.stagesCompleted.length &gt; 0 &amp;&amp; vars.caseManagerDecisions.stagesCompleted.some((stage) =&gt; stage.stageName == '2 – Human Investigation Review')))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_eventSubprocessStagesExitedInclusiveGateway-stopStageSlaMessageEvent_Stage_IDZfXs" sourceRef="eventSubprocessStagesExitedInclusiveGateway" targetRef="stopStageSlaMessageEvent_Stage_IDZfXs">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:((vars.caseManagerDecisions.stagesExited != null &amp;&amp; vars.caseManagerDecisions.stagesExited.length &gt; 0 &amp;&amp; vars.caseManagerDecisions.stagesExited.some((stage) =&gt; stage.stageName == '3 – AI Network Investigation')) || (vars.caseManagerDecisions.stagesCompleted != null &amp;&amp; vars.caseManagerDecisions.stagesCompleted.length &gt; 0 &amp;&amp; vars.caseManagerDecisions.stagesCompleted.some((stage) =&gt; stage.stageName == '3 – AI Network Investigation')))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_eventSubprocessStagesExitedInclusiveGateway-stopStageSlaMessageEvent_Stage_S3oda5" sourceRef="eventSubprocessStagesExitedInclusiveGateway" targetRef="stopStageSlaMessageEvent_Stage_S3oda5">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:((vars.caseManagerDecisions.stagesExited != null &amp;&amp; vars.caseManagerDecisions.stagesExited.length &gt; 0 &amp;&amp; vars.caseManagerDecisions.stagesExited.some((stage) =&gt; stage.stageName == '4 – Final Report &amp; Closure')) || (vars.caseManagerDecisions.stagesCompleted != null &amp;&amp; vars.caseManagerDecisions.stagesCompleted.length &gt; 0 &amp;&amp; vars.caseManagerDecisions.stagesCompleted.some((stage) =&gt; stage.stageName == '4 – Final Report &amp; Closure')))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_eventSubprocessStagesExitedInclusiveGateway-eventSubprocessNoValidStagesToExitEndEvent" sourceRef="eventSubprocessStagesExitedInclusiveGateway" targetRef="eventSubprocessNoValidStagesToExitEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions.stagesExited == null || vars.caseManagerDecisions.stagesExited.length == 0 || !vars.caseManagerDecisions.stagesExited.some((stage) =&gt; stage.stageName == '1 – Initial AI Screening' || stage.stageName == '2 – Human Investigation Review' || stage.stageName == '3 – AI Network Investigation' || stage.stageName == '4 – Final Report &amp; Closure')) &amp;&amp; (vars.caseManagerDecisions.stagesCompleted == null || vars.caseManagerDecisions.stagesCompleted.length == 0 || !vars.caseManagerDecisions.stagesCompleted.some((stage) =&gt; stage.stageName == '1 – Initial AI Screening' || stage.stageName == '2 – Human Investigation Review' || stage.stageName == '3 – AI Network Investigation' || stage.stageName == '4 – Final Report &amp; Closure'))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_loopExclusiveGateway-endCancelTaskLoopNode" sourceRef="loopExclusiveGateway" targetRef="endCancelTaskLoopNode">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions == null || vars.caseManagerDecisions.tasksToCancel == null || vars.caseManagerDecisions.tasksToCancel.length == 0)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
