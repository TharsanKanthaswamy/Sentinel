            </uipath:context>
            <uipath:input name="caseManagerInput" type="json" target="body"><![CDATA[{"caseRulesDecisions":"=js:(vars.caseRulesDecisions)","caseCurrentExecutionState":"=js:({ \"version\": 1, \"eventIdentifier\": vars.EventSubProcessEventIdentifier, \"event\": { \"type\": vars.EventSubProcessLatestEventType, \"parameters\": vars.EventSubProcessLatestEventParams, \"isExternal\": (vars.EventSubProcessLatestEventType == \"CaseEntered\" || vars.EventSubProcessLatestEventType == \"TaskCompleted\") ? false : true }, \"state\": { ...vars.caseState, \"vars\": { \"RPA Workflow\": { \"Error\": (vars.error), \"riskScore\": (vars.riskScore2), \"accountId\": (vars.accountId2), \"riskLevel\": (vars.riskLevel2), \"flags\": (vars.flags2), \"isSuspicious\": (vars.isSuspicious2) }, \"SimpleApprovalApp\": { \"Error\": (vars.error2), \"Comment\": (vars.comment), \"Action\": (vars.action), \"hitlTask\": (vars.hitlTask) }, \"Received event params\": { \"response\": (vars.mainEventSubprocessResponse.connectorResponse) }, \"APIEvent\": (vars.mainEventSubprocessResponse.apiEvent) } } })"}]]></uipath:input>
