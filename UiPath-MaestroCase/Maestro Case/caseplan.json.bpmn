        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions.stagesEntered.some((stage) =&gt; stage.stageName == '1 – Initial AI Screening'))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_eventSubprocessStagesEnteredInclusiveGateway-startStageSlaMessageEvent_Stage_RBNERo" sourceRef="eventSubprocessStagesEnteredInclusiveGateway" targetRef="startStageSlaMessageEvent_Stage_RBNERo">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions.stagesEntered.some((stage) =&gt; stage.stageName == '2 – Human Investigation Review'))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_eventSubprocessStagesEnteredInclusiveGateway-startStageSlaMessageEvent_Stage_IDZfXs" sourceRef="eventSubprocessStagesEnteredInclusiveGateway" targetRef="startStageSlaMessageEvent_Stage_IDZfXs">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions.stagesEntered.some((stage) =&gt; stage.stageName == '3 – AI Network Investigation'))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_eventSubprocessStagesEnteredInclusiveGateway-startStageSlaMessageEvent_Stage_S3oda5" sourceRef="eventSubprocessStagesEnteredInclusiveGateway" targetRef="startStageSlaMessageEvent_Stage_S3oda5">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions.stagesEntered.some((stage) =&gt; stage.stageName == '4 – Final Report &amp; Closure'))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_eventSubprocessStagesEnteredInclusiveGateway-eventSubprocessNoValidStagesToEnterEndEvent" sourceRef="eventSubprocessStagesEnteredInclusiveGateway" targetRef="eventSubprocessNoValidStagesToEnterEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(!vars.caseManagerDecisions.stagesEntered.some((stage) =&gt; stage.stageName == '1 – Initial AI Screening' || stage.stageName == '2 – Human Investigation Review' || stage.stageName == '3 – AI Network Investigation' || stage.stageName == '4 – Final Report &amp; Closure'))</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="eventSubprocessNoTasksToRunEdge" sourceRef="eventSubprocessExclusiveGateway" targetRef="noTasksToRunExclusiveGateway" />
      <bpmn:sequenceFlow id="edge_eventSubprocessExclusiveGateway-runTasksInclusiveGateway" sourceRef="eventSubprocessExclusiveGateway" targetRef="runTasksInclusiveGateway">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions?.caseExited?.exited != true) &amp;&amp; (vars.caseManagerDecisions?.tasksToRun != null &amp;&amp; vars.caseManagerDecisions?.tasksToRun.length &gt; 0)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="skipMessageEdge" sourceRef="noTasksToRunExclusiveGateway" targetRef="eventSubprocessEndEvent" />
      <bpmn:sequenceFlow id="sendMessageEdge" sourceRef="noTasksToRunExclusiveGateway" targetRef="SendCaseEndMessageEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:(vars.caseManagerDecisions != null &amp;&amp; vars.caseManagerDecisions.caseResolution != null &amp;&amp; vars.caseManagerDecisions.caseResolution.type != null) ? vars.caseManagerDecisions.caseResolution.type == "completed" : false</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-t7NUAoGHu_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="t7NUAoGHu_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "RPA Workflow" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-tw80GuqRs_SendMessageEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="tw80GuqRs_SendMessageEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; "SimpleApprovalApp" === task.taskName)</bpmn:conditionExpression>
      </bpmn:sequenceFlow>
      <bpmn:sequenceFlow id="edge_runTasksInclusiveGateway-unknownTaskFallbackEndEvent" sourceRef="runTasksInclusiveGateway" targetRef="unknownTaskFallbackEndEvent">
        <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=js:vars.caseManagerDecisions?.tasksToRun?.some((task) =&gt; !["RPA Workflow","SimpleApprovalApp"].includes(task.taskName))</bpmn:conditionExpression>
